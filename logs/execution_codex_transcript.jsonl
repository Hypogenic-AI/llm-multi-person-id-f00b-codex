{"type":"item.started","item":{"id":"item_61","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport pandas as pd, json, re\nfrom pathlib import Path\nm=pd.read_csv('results/metrics_by_case.csv')\nwide=m.pivot(index='case_id', columns='method', values='wder').reset_index()\nmeta=m.drop_duplicates('case_id')[['case_id','dataset','recording_id','noise_level','seed','num_speakers','n_words']]\nwide=meta.merge(wide,on='case_id')\nfor method in ['continuity_smoothing','llm_no_profile','llm_profile']:\n    wide[f'wder_reduction_{method}']=wide['noisy_labels']-wide[method]\n    wide[f'outcome_{method}']=wide[f'wder_reduction_{method}'].map(lambda x: 'improved' if x>1e-9 else ('worse' if x < -1e-9 else 'unchanged'))\nwide.to_csv('results/error_analysis.csv', index=False)\nusage=[]\nfor line in open('results/model_outputs/llm_outputs.jsonl'):\n    r=json.loads(line)\n    u=r.get('usage') or {}\n    usage.append({'model':r.get('model'), 'prompt_tokens':u.get('prompt_tokens') or u.get('input_tokens') or 0, 'completion_tokens':u.get('completion_tokens') or u.get('output_tokens') or 0})\nudf=pd.DataFrame(usage)\nasr=[]\nfor line in open('results/cache/asr_transcriptions.jsonl'):\n    r=json.loads(line)\n    asr.append({'model':r.get('model'), 'duration_seconds':r.get('duration',0), 'words':len(re.findall(r\\\"[A-Za-z0-9']+\\\", r.get('text','').lower()))})\nasrdf=pd.DataFrame(asr)\nllm_in=float(udf.prompt_tokens.sum())\nllm_out=float(udf.completion_tokens.sum())\nasr_seconds=float(asrdf.duration_seconds.sum())\nsummary={\n  'llm_model':'gpt-4.1-mini',\n  'llm_calls':int(len(udf)),\n  'llm_prompt_tokens':int(llm_in),\n  'llm_completion_tokens':int(llm_out),\n  'llm_input_price_per_million_usd':0.40,\n  'llm_output_price_per_million_usd':1.60,\n  'llm_estimated_cost_usd':round(llm_in/1_000_000*0.40 + llm_out/1_000_000*1.60, 6),\n  'asr_model':'gpt-4o-mini-transcribe',\n  'asr_segments':int(len(asrdf)),\n  'asr_audio_seconds':roun